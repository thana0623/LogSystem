<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.logsys.dao.postgres.ServiceMapper">

    <resultMap id="serviceResultMap" type="com.logsys.model.entity.ServiceEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="displayName" column="display_name"/>
        <result property="description" column="description"/>
        <result property="language" column="language"/>
        <result property="repositoryUrl" column="repository_url"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="serviceResultMap">
        SELECT id, name, display_name, description, language, repository_url, created_at, updated_at
        FROM services
        ORDER BY created_at DESC
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM services
    </select>

    <select id="findByName" resultMap="serviceResultMap">
        SELECT id, name, display_name, description, language, repository_url, created_at, updated_at
        FROM services
        WHERE name = #{name}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="service.id">
        INSERT INTO services (name, description, language)
        VALUES (#{service.name}, #{service.description}, #{service.language})
    </insert>

    <delete id="deleteByName">
        DELETE FROM services WHERE name = #{name}
    </delete>

</mapper>
